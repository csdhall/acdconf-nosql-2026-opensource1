# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_SUMMARIZER_MODEL=gpt-5.4
OPENAI_EXTRACTOR_MODEL=gpt-5.4
OPENAI_TEMPERATURE=0
MOCK_OPENAI=false

# Optional: used only by scripts/load_test_data.py when use_loading_models=true
LOADING_OPENAI_MODEL=gpt-5.4
LOADING_OPENAI_SUMMARIZER_MODEL=gpt-5.4
LOADING_OPENAI_EXTRACTOR_MODEL=gpt-5.4

# OpenAI embeddings (Entity Graph retrieval)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# Cosmos DB for NoSQL
COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_KEY=
COSMOS_DATABASE=

COSMOS_CONTAINER_DIRECT_LLM=direct_llm_sessions
COSMOS_CONTAINER_SLIDING_WINDOW=sliding_window_sessions
COSMOS_CONTAINER_HIERARCHICAL=hierarchical_sessions
COSMOS_CONTAINER_ENTITY_GRAPH_SESSIONS=entity_graph_sessions
COSMOS_CONTAINER_ENTITY_GRAPH_ENTITIES=entity_graph_entities

# Feature flags for native Cosmos retrieval in Entity Graph
COSMOS_ENABLE_VECTOR_SEARCH=true
COSMOS_ENABLE_FULL_TEXT_SEARCH=false

# Set to false when using a local Cosmos emulator with self-signed TLS.
COSMOS_VERIFY_SSL=true

# System prompt
SYSTEM_PROMPT="You are a helpful assistant with persistent memory. Use the injected memory context to answer questions about prior turns. Only state details that are explicitly present in the conversation or injected memory. If the needed information is missing, say you do not know and ask for the missing detail."
